# Copy to .env.production (project root) on the VPS BEFORE running `npm run build`.
#   cp deploy/frontend.env.production.example .env.production && nano .env.production
#
# ⚠️  NEXT_PUBLIC_* values are baked into the build at BUILD TIME.
#     If you change this, you must rebuild the frontend (npm run build) and
#     restart PM2 for it to take effect.

# Public URL the browser uses to reach the API. Because the frontend derives
# the Socket.io URL from this (API_BASE minus "/api"), keep the "/api" suffix.
NEXT_PUBLIC_API_BASE_URL=https://numu.com.pk/api

# Copy to backend/.env on the VPS and fill in real values.
#   cp deploy/backend.env.production.example backend/.env && nano backend/.env

PORT=4000

# PostgreSQL (local, created by 01-server-setup.sh)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=numu
DB_USER=numu
DB_PASSWORD=PASTE_PASSWORD_PRINTED_BY_SETUP_SCRIPT

# CORS — must be your real https domain (the browser origin)
CLIENT_ORIGIN=https://YOUR_DOMAIN

# JWT secret — generate a fresh one on the server:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_NEW_ONE

# Resend (email OTP) — https://resend.com/api-keys
RESEND_API_KEY=re_your_key_here
# EMAIL_FROM must be a verified sender/domain in Resend for real delivery.
EMAIL_FROM=noreply@YOUR_DOMAIN
